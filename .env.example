# =============================================================================
# Nearr — local environment template
# =============================================================================
# Copy to `.env` and fill in REAL values. Never commit `.env` itself.
# Server/secret values (Edge Function, scripts) should ALSO be set via
# `supabase secrets set ...` for production — this file is for local dev only.
#
# Variable naming convention:
#   EXPO_PUBLIC_*  → inlined into the Expo JS bundle, visible to the client.
#                    Use restricted Google Cloud / Supabase keys ONLY.
#   everything else → server / Edge Function / Node script. Never imported
#                    from React Native client code.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. CLIENT  (Expo, public — bundled into the app)
# -----------------------------------------------------------------------------

# Supabase project (public values)
#   used by: lib/supabase.ts, app.config.js (extra)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps + Places key used on-device (iOS map tiles, Android map tiles,
# in-app Places search, address-first geocoding for the share flow).
# Restrict in GCP to your iOS bundle ID + Android SHA-1, and enable:
#   - Maps SDK for iOS
#   - Maps SDK for Android
#   - Places API
#   - Geocoding API   ← required for services/placesService.ts geocodeAddress()
#                       (used to verify a share's address before silent-save)
#   used by: services/placesService.ts, app.config.js (ios.config.googleMapsApiKey,
#            android.config.googleMaps.apiKey, extra.googlePlacesKey)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# URL of the deployed `process-share-link` Supabase Edge Function. If unset,
# the iOS Share Extension always falls back to opening the host app.
#   used by: ShareExtension.tsx
EXPO_PUBLIC_PROCESS_SHARE_LINK_URL=

# Feature flags (both default false). See docs/ENVIRONMENT.md for behavior.
#   used by: lib/demoMode.ts, lib/mapPreview.ts
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_MAP_PREVIEW_MODE=false

# Optional verbose local debug logging. When true in a dev build, debug-gated
# logs become visible in Metro/LogBox. Default is quiet.
#   used by: lib/logger.ts
EXPO_PUBLIC_DEBUG_LOGS=false


# -----------------------------------------------------------------------------
# 2. NATIVE BUILD OVERRIDES  (legacy aliases — optional)
# -----------------------------------------------------------------------------
# app.config.js will fall back to these if EXPO_PUBLIC_GOOGLE_MAPS_API_KEY is
# unset, so iOS/Android can use distinct restricted keys if you prefer. Leave
# blank to use the single EXPO_PUBLIC_GOOGLE_MAPS_API_KEY everywhere.
#   used by: app.config.js
GOOGLE_MAPS_IOS_KEY=
GOOGLE_MAPS_ANDROID_KEY=


# -----------------------------------------------------------------------------
# 3. SERVER / EDGE FUNCTION  (NEVER bundle into the client)
# -----------------------------------------------------------------------------
# In production, set these with:
#   supabase secrets set GEMINI_API_KEY=... GOOGLE_PLACES_KEY=...
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by the
# Supabase Edge runtime — do NOT set them yourself.

# Server-side Google Places Text Search key. Restrict by IP to Supabase's
# Edge egress range, and enable BOTH:
#   - Places API
#   - Geocoding API   ← required for the Edge Function's address-first
#                       verification gate (verifyPlaceAtAddressServer).
# Must be a DIFFERENT key from EXPO_PUBLIC_GOOGLE_MAPS_API_KEY.
#   used by: supabase/functions/process-share-link/index.ts,
#            scripts/evalShareExtraction.ts
GOOGLE_PLACES_KEY=

# Gemini 1.5 Flash key for server-side place extraction. If missing, the
# Edge Function falls back to a deterministic heuristic (still functional).
#   used by: supabase/functions/process-share-link/index.ts,
#            lib/aiExtractPlace.ts, scripts/evalShareExtraction.ts
GEMINI_API_KEY=

# Optional: only needed if you run `supabase db push` against a remote DB
# from a non-interactive CLI session.
SUPABASE_DATABASE_PASSWORD=


# -----------------------------------------------------------------------------
# 4. TRANSCRIPTION  (server / Edge Function only)
# -----------------------------------------------------------------------------
# Pick exactly one provider. The Edge Function and lib/transcription dispatch
# on this value:
#   placeholder  → no transcription, pipeline runs metadata-only (default)
#   soscripted   → calls https://soscripted.com/transcript-api (paid)
#   self_hosted  → calls our FastAPI service (transcription-service/)
#   used by: lib/transcription/index.ts,
#            supabase/functions/process-share-link/index.ts
TRANSCRIPTION_PROVIDER=placeholder

# Required when TRANSCRIPTION_PROVIDER=self_hosted.
# Either the bare host (https://host.example.com) or with /transcribe — the
# Edge Function normalizes the URL and appends the right path per call.
#   used by: lib/transcription/providers/selfHosted.ts,
#            supabase/functions/process-share-link/index.ts
SELF_HOSTED_TRANSCRIPTION_URL=

# Shared secret between the Edge Function and the FastAPI service. Sent as
# the `x-api-key` header. Must match the value in transcription-service/.env.
#   used by: lib/transcription/providers/selfHosted.ts,
#            supabase/functions/process-share-link/index.ts,
#            transcription-service/app.py
TRANSCRIPTION_SERVICE_API_KEY=

# Required when TRANSCRIPTION_PROVIDER=soscripted. Sent as a Bearer token.
#   used by: lib/transcription/providers/soscripted.ts,
#            supabase/functions/process-share-link/index.ts
SOSCRIPTED_API_KEY=


# -----------------------------------------------------------------------------
# 5. SCRIPTS  (Node CLI helpers in scripts/)
# -----------------------------------------------------------------------------
# Convenience override for scripts/testProcessShareLink.ts. Falls back to
# EXPO_PUBLIC_PROCESS_SHARE_LINK_URL above if unset, so this is purely
# optional.
PROCESS_SHARE_LINK_URL=


# -----------------------------------------------------------------------------
# 6. DEPRECATED / LEGACY  (still read, will be removed in a future release)
# -----------------------------------------------------------------------------
# `EXPO_PUBLIC_GOOGLE_PLACES_KEY` was the original name for the on-device
# Places key. It is still accepted as a fallback by services/placesService.ts
# and the Edge Function, but new setups should use
# `EXPO_PUBLIC_GOOGLE_MAPS_API_KEY` (canonical) instead.
#   used by (fallback only): services/placesService.ts,
#                            supabase/functions/process-share-link/index.ts
# EXPO_PUBLIC_GOOGLE_PLACES_KEY=

# `TRANSCRIPTION_API_KEY` was a placeholder env var read by the original
# stub provider. Setting it has no effect on real providers — use
# `SOSCRIPTED_API_KEY` or `TRANSCRIPTION_SERVICE_API_KEY` instead.
#   used by (no-op): lib/transcription/providers/placeholder.ts
# TRANSCRIPTION_API_KEY=
