EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Single key used by services/placesService for both Text Search + Details.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
# Native Maps SDK keys (referenced from app.json ios.config / android.config).
GOOGLE_MAPS_IOS_KEY=
GOOGLE_MAPS_ANDROID_KEY=
# Set to `true` for full-app local UX testing without external APIs.
# Mocks Supabase (auth + profile + saved_places), Google Places, Google Maps,
# location, and notifications. Triple-guarded on __DEV__ — production builds
# ignore this flag entirely.
EXPO_PUBLIC_DEMO_MODE=
# Set to `true` to render the real react-native-maps map against seeded local
# data without Supabase, Google Places, or real device location. Useful for
# polishing the map UI on a dev device. Triple-guarded on __DEV__. If both
# this and EXPO_PUBLIC_DEMO_MODE are true, Demo Mode wins.
EXPO_PUBLIC_MAP_PREVIEW_MODE=

# --- Transcription fallback (server / scripts ONLY) -----------------------
# Used by lib/transcription/* to optionally transcribe a shared video's audio
# when its caption does not contain the place name. NO provider is wired up
# yet -- see README "Transcription fallback" section.
#
# DO NOT prefix these with EXPO_PUBLIC_. They must NEVER ship in the Expo
# client bundle. They are only read by Node scripts (e.g. eval) and, in
# production, by a Supabase Edge Function that wraps the transcription call.
TRANSCRIPTION_PROVIDER=
TRANSCRIPTION_API_KEY=
