# --- Server ---
PORT=8088
LOG_LEVEL=info
ENV=development

# --- Auth ---
# Required header: X-NEARR-EVIDENCE-KEY
NEARR_EVIDENCE_SERVER_KEY=replace-with-long-random-string

# --- Timeouts (seconds) ---
REQUEST_TIMEOUT_SECONDS=45
PROVIDER_TIMEOUT_SECONDS=20
HTTP_TIMEOUT_SECONDS=15

# --- Instagram ---
# Optional. If set, instaloader will log in (improves profile bio reliability).
# Leave blank for anonymous mode (works for many public profiles but rate-limits faster).
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
# Path inside the container where instaloader can persist its session
INSTALOADER_SESSION_DIR=/data/instaloader

# Optional cookies file for yt-dlp (Netscape format). Helps with Instagram video extraction.
YTDLP_COOKIES_FILE=

# --- Whisper (feature flag, off by default for MVP) ---
ENABLE_WHISPER=false
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# --- Third-party profile fallback (optional) ---
# If you wire an external profile provider later (e.g. RapidAPI, ScrapingDog), set its key here.
THIRD_PARTY_PROFILE_PROVIDER=
THIRD_PARTY_PROFILE_API_KEY=
