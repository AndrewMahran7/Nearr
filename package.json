{
  "name": "nearr",
  "version": "0.1.0",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package",
    "eval:share-extraction": "ts-node --project scripts/tsconfig.json scripts/evalShareExtraction.ts",
    "eval:share-agent-shadow": "ts-node --project scripts/tsconfig.json scripts/evalShareAgentShadow.ts",
    "test:address-match": "ts-node -P scripts/tsconfig.json scripts/testAddressMatch.ts",
    "test:safety-description-only": "ts-node -P scripts/tsconfig.json scripts/testSafetyDescriptionOnly.ts",
    "test:recovery-hints": "ts-node -P scripts/tsconfig.json scripts/testRecoveryHints.ts",
    "test:manual-fallback": "ts-node -P scripts/tsconfig.json scripts/testManualFallback.ts",
    "test:multi-address": "ts-node -P scripts/tsconfig.json scripts/testMultiAddressExtraction.ts",
    "test:share-remote": "ts-node -P scripts/tsconfig.json scripts/testProcessShareLinkRemote.ts",
    "export:share-gold-labels": "ts-node -P scripts/tsconfig.json scripts/exportShareGoldLabels.ts",
    "eval:share-gold": "ts-node -P scripts/tsconfig.json scripts/evalShareGold.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.0",
    "expo-dev-client": "~4.0.29",
    "expo-linking": "~6.3.0",
    "expo-location": "~17.0.0",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-share-extension": "^1.10.7",
    "expo-status-bar": "~1.12.0",
    "expo-task-manager": "~11.8.0",
    "nearr-shared-auth": "file:./modules/nearr-shared-auth",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-maps": "1.14.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "~18.2.79",
    "patch-package": "^8.0.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.3"
  },
  "private": true
}
