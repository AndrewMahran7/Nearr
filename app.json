{
  "expo": {
    "name": "Nearr",
    "slug": "nearr",
    "scheme": "nearr",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nearr.ios",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Nearr uses your location to notify you when you are near saved places.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Nearr uses your location in the background to notify you when you are near saved places.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCDEl9gx-qw8VhFObsJ1mxGTAO2gjnNBKM"
      }
    },
    "android": {
      "package": "com.nearr.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "https"
            }
          ]
        },
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCDEl9gx-qw8VhFObsJ1mxGTAO2gjnNBKM"
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Nearr to use your location to notify you near saved places."
        }
      ],
      "expo-notifications",
      "./plugins/withAndroidShareIntent",
      [
        "expo-share-extension",
        {
          "activationRules": [
            { "type": "url", "max": 1 },
            { "type": "text" }
          ],
          "excludedPackages": [
            "expo-dev-client",
            "expo-splash-screen",
            "expo-updates",
            "expo-notifications",
            "expo-location",
            "expo-task-manager"
          ],
          "height": 220
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "$SUPABASE_URL",
      "supabaseAnonKey": "$SUPABASE_ANON_KEY",
      "googlePlacesKey": "$GOOGLE_PLACES_KEY",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2ec7a08a-2078-4232-a244-c9d16fb75ffe"
      }
    }
  }
}
