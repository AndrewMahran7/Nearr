{
  "expo": {
    "name": "Nearr",
    "slug": "nearr",
    "scheme": "nearr",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nearr.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Nearr uses your location to notify you when you are near saved places.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Nearr uses your location in the background to notify you when you are near saved places.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      },
      "config": {
        "googleMapsApiKey": "$GOOGLE_MAPS_IOS_KEY"
      }
    },
    "android": {
      "package": "com.nearr.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "https"
            }
          ]
        },
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ],
      "config": {
        "googleMaps": {
          "apiKey": "$GOOGLE_MAPS_ANDROID_KEY"
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Nearr to use your location to notify you near saved places."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "supabaseUrl": "$SUPABASE_URL",
      "supabaseAnonKey": "$SUPABASE_ANON_KEY",
      "googlePlacesKey": "$GOOGLE_PLACES_KEY",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2ec7a08a-2078-4232-a244-c9d16fb75ffe"
      }
    }
  }
}
