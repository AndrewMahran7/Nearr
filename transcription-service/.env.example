# Required to authenticate calls from the Supabase Edge Function.
# Generate with: openssl rand -hex 32
TRANSCRIPTION_SERVICE_API_KEY=

# Whisper model size: tiny | base | small | medium | large
# "base" is a good speed/quality compromise on CPU. Use "small" or larger
# only if you have a GPU.
WHISPER_MODEL=base

# "cpu" or "cuda". Use "cuda" only on a host with NVIDIA + CUDA torch.
WHISPER_DEVICE=cpu

# Hard wall-clock cap for the whole /transcribe request, in seconds.
# Must be smaller than the Supabase Edge Function's request timeout.
TRANSCRIPTION_TIMEOUT_SEC=120

# Sub-budget for the yt-dlp download step.
YTDLP_TIMEOUT_SEC=45

# Truncate transcripts longer than this many characters.
MAX_TRANSCRIPT_CHARS=8000

# Optional: standard Python logging level.
LOG_LEVEL=INFO
